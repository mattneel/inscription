union MaybeI32:
  none
  some value: i32

make maybe flag: i1 gives MaybeI32:
  MaybeI32.some with value be 42 when flag
  otherwise MaybeI32.none

value or zero maybe: MaybeI32 gives i32:
  match maybe:
    MaybeI32.some with value gives value
    otherwise gives 0

main gives i32:
  let maybe be make maybe true
  value or zero maybe
