union ParseResult:
  value value: i32
  error code: u8 and offset: i32

main gives i32:
  let result be ParseResult.error with code be 2 and offset be 8
  let total be 0
  let errors be 0
  match result:
    ParseResult.value with value:
      total becomes total plus value
    ParseResult.error with code as c and offset as pos:
      errors becomes errors plus (c as i32) plus pos
    otherwise:
      total becomes total
  total plus errors
