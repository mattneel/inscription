type Byte be u8
type Word be u16

enum Mode: Byte:
  idle be 0
  active be 1

packed layout record Header:
  mode: Mode
  length: Word

main gives i32:
  let bytes be array of 3 Byte containing 1, 42, 0
  let header be read Header from bytes at 0
  header.length as i32 when header.mode is equal to Mode.active
  otherwise 0
