union MaybeI32:
  none
  some value: i32

unwrap positive maybe: MaybeI32 gives i32:
  require match maybe:
    MaybeI32.some with value gives value is greater than 0
    otherwise gives false
  match maybe:
    MaybeI32.some with value gives value
    otherwise gives 0

main gives i32:
  unwrap positive MaybeI32.some with value be 7
