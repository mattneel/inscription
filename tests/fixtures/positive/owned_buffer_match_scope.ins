enum Mode: u8:
  small be 0
  large be 1

match owned mode: Mode gives i32:
  let result be 0
  match mode:
    Mode.small:
      let cells be owned buffer of 2 i32 filled with 5
      result becomes cells at 0
    Mode.large:
      let cells be owned buffer of 4 i32 filled with 9
      result becomes cells at 3
    otherwise:
      result becomes 1
  result

main gives i32:
  match owned Mode.large
