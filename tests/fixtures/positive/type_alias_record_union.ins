record Point:
  x: i32
  y: i32

union MaybePoint:
  none
  some point: Point

type Position be Point
type OptionalPosition be MaybePoint

score maybe maybe: OptionalPosition gives i32:
  match maybe:
    MaybePoint.some with point gives point.x plus point.y
    otherwise gives 0

main gives i32:
  let p: Position be Point with x be 3 and y be 4
  score maybe MaybePoint.some with point be p
