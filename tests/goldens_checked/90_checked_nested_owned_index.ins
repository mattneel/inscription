checked nested owned index i: i32 gives i32:
  let result be 0
  if true:
    let cells be owned buffer of 4 i32 filled with 0
    cells at 0 becomes 1
    cells at 1 becomes 2
    cells at 2 becomes 3
    cells at 3 becomes 4
    result becomes cells at i
  otherwise:
    result becomes 0
  result

main gives i32:
  checked nested owned index 2
