program                  ::= { top_level_item } ;
top_level_item           ::= constant_decl | check_stmt | record_decl | layout_record_decl | packed_layout_record_decl | phrase_definition ;
constant_decl            ::= "constant" identifier ":" scalar_type "be" expression ;
check_stmt               ::= "check" expression ;
record_decl              ::= "record" record_name ":" newline indent record_field { record_field } dedent ;
layout_record_decl       ::= "layout" "record" record_name ":" newline indent layout_record_field { layout_record_field } dedent ;
packed_layout_record_decl ::= "packed" "layout" "record" record_name ":" newline indent layout_record_field { layout_record_field } dedent ;
record_field             ::= field_name ":" scalar_type ;
layout_record_field      ::= field_name ":" scalar_integer_type ;
phrase_definition        ::= gives_definition | does_definition ;
gives_definition         ::= phrase_template "gives" scalar_type ":" gives_body ;
does_definition          ::= phrase_template "does" ":" does_body ;
phrase_template          ::= phrase_part { phrase_part } ;
phrase_part              ::= word | hole ;
hole                     ::= identifier ":" hole_type ;
hole_type                ::= scalar_type | buffer_type | record_type ;
record_type              ::= record_name ;
scalar_type              ::= "i1" | "i8" | "i16" | "i32" | "i64" | "u8" | "u16" | "u32" | "u64" ;
scalar_integer_type      ::= "i8" | "i16" | "i32" | "i64" | "u8" | "u16" | "u32" | "u64" ;
buffer_type              ::= "buffer" "of" buffer_length scalar_integer_type ;
buffer_length            ::= integer | identifier | "(" expression ")" ;
gives_body               ::= { body_item } value_block ;
does_body                ::= body_item { body_item } ;
body_item                ::= check_stmt | let_binding | buffer_binding | assignment | field_assignment | buffer_store | layout_write | phrase_call_step | while_block | for_block | for_each_block | if_block ;
step                     ::= body_item ;
let_binding              ::= "let" identifier optional_type_annotation "be" expression ;
optional_type_annotation ::= | ":" ( scalar_type | record_type ) ;
buffer_binding           ::= "let" identifier "be" "buffer" "of" buffer_length scalar_integer_type "filled" "with" expression ;
assignment               ::= identifier "becomes" expression ;
field_assignment         ::= identifier "." field_name "becomes" expression ;
buffer_store             ::= identifier "at" expression "becomes" expression ;
layout_write             ::= "write" identifier "into" identifier "at" expression ;
phrase_call_step         ::= phrase_call ;
while_block              ::= "while" expression ":" newline indent step { step } dedent ;
for_block                ::= "for" identifier "from" expression "up" "to" expression optional_by ":" newline indent step { step } dedent ;
optional_by              ::= | "by" integer ;
for_each_block           ::= "for" "each" "index" identifier "of" identifier ":" newline indent step { step } dedent ;
if_block                 ::= "if" expression ":" newline indent step { step } dedent
                             "otherwise" ":" newline indent step { step } dedent ;
value_block              ::= expression
                           | when_line { when_line } otherwise_line ;
when_line                ::= expression "when" expression ;
otherwise_line           ::= "otherwise" expression ;
expression               ::= boolean_or ;
boolean_or               ::= boolean_and { "or" boolean_and } ;
boolean_and              ::= comparison { "and" comparison } ;
comparison               ::= bitwise_or [ comparator bitwise_or ] ;
comparator               ::= "is equal to" | "is not equal to" | "is less than" | "is less than or equal to" | "is greater than" | "is greater than or equal to" ;
bitwise_or               ::= bitwise_xor { "bitwise or" bitwise_xor } ;
bitwise_xor              ::= bitwise_and { "bitwise xor" bitwise_and } ;
bitwise_and              ::= shift { "bitwise and" shift } ;
shift                    ::= sum { ( "shifted left by" | "shifted right by" ) sum } ;
sum                      ::= product { ( "plus" | "minus" ) product } ;
product                  ::= unary { ( "times" | "divided by" | "remainder" ) unary } ;
unary                    ::= "not" unary | "bitwise not" unary | cast ;
cast                     ::= postfix { "as" scalar_type } ;
postfix                  ::= primary { field_access_suffix | buffer_load_suffix } ;
field_access_suffix      ::= "." field_name ;
buffer_load_suffix       ::= "at" primary ;
primary                  ::= integer | "zero" | boolean | length_expression | size_expression | alignment_expression | offset_expression | layout_read | record_constructor | identifier | phrase_call | "(" expression ")" ;
record_constructor       ::= record_name "with" record_initializer { "and" record_initializer } ;
record_initializer       ::= field_name "be" expression ;
length_expression        ::= "length" "of" identifier ;
size_expression          ::= "size" "of" record_name ;
alignment_expression     ::= "alignment" "of" record_name ;
offset_expression        ::= "offset" "of" field_name "in" record_name ;
layout_read              ::= "read" record_name "from" identifier "at" expression ;
boolean                  ::= "true" | "false" ;
phrase_call              ::= ? a declared phrase_template with each hole filled by a scalar expression, visible buffer binding, or visible record binding ? ;
word                     ::= ? [a-z][a-z0-9_]* literal phrase word ? ;
identifier               ::= ? [a-z][a-z0-9_]*, excluding reserved words ? ;
field_name               ::= ? [a-z][a-z0-9_]* field identifier ? ;
record_name              ::= ? [A-Z][A-Za-z0-9_]* nominal record type name ? ;
integer                  ::= ? base-10 decimal integer literal ? ;
newline                  ::= ? line break ? ;
indent                   ::= ? greater indentation than the control-flow header ? ;
dedent                   ::= ? indentation returning to the enclosing block ? ;
