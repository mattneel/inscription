program          ::= { phrase_definition } ;
phrase_definition ::= phrase_template "gives" type ":" phrase_body ;
phrase_template  ::= phrase_part { phrase_part } ;
phrase_part      ::= word | hole ;
hole             ::= identifier ":" type ;
type             ::= "i32" ;
phrase_body      ::= { let_binding } value_block ;
let_binding      ::= "let" identifier "be" expression ;
value_block      ::= expression
                   | when_line { when_line } otherwise_line ;
when_line        ::= expression "when" comparison ;
otherwise_line   ::= "otherwise" expression ;
comparison       ::= expression comparator expression ;
comparator       ::= "is equal to" | "is not equal to" | "is less than" | "is less than or equal to" | "is greater than" | "is greater than or equal to" ;
expression       ::= term { ( "plus" | "minus" ) term } ;
term             ::= factor { "times" factor } ;
factor           ::= integer | "zero" | identifier | phrase_call ;
phrase_call      ::= ? a declared phrase_template with each hole filled by an expression ? ;
word             ::= ? [a-z][a-z0-9_]* literal phrase word ? ;
identifier       ::= ? [a-z][a-z0-9_]*, excluding reserved words ? ;
integer          ::= ? signed 32-bit base-10 integer ? ;
