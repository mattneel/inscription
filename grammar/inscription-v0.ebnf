program         ::= { function } ;
function        ::= function_header function_block ( "End function." | implicit_function_end ) ;
function_header ::= "Function" identifier "takes" ( "no parameters" | name_list ) "." ;
block           ::= { statement } ;
function_block  ::= { set_stmt | if_stmt | while_stmt } ( return_stmt | implicit_return_stmt )
                  | { statement } ;
statement       ::= set_stmt | if_stmt | while_stmt | return_stmt ;
set_stmt        ::= "Set" identifier "to" expression "." ;
if_stmt         ::= "If" comparison "then." block "Otherwise." block "End if." ;
while_stmt      ::= "While" comparison "do." block "End while." ;
return_stmt     ::= "Return" expression "." ;
implicit_return_stmt ::= expression "." ;
implicit_function_end ::= ? EOF or immediately before the next function_header after a tail return ? ;
name_list       ::= identifier | identifier "and" identifier | comma_name_list ;
comma_name_list  ::= identifier "," identifier { "," identifier } [ "," "and" identifier ] ;
comparison      ::= expression comparator expression ;
comparator      ::= "is equal to" | "is not equal to" | "is less than" | "is less than or equal to" | "is greater than" | "is greater than or equal to" ;
expression      ::= term { ( "plus" | "minus" ) term } ;
term            ::= factor { "times" factor } ;
factor          ::= integer | identifier | call ;
call            ::= "call" identifier "with" ( "no arguments" | argument_list ) ;
argument_list   ::= expression | expression "and" expression | expression "," expression { "," expression } [ "," "and" expression ] ;
identifier      ::= ? [a-z][a-z0-9_]*, excluding reserved words ? ;
integer         ::= ? signed 32-bit base-10 integer ? ;
